# Normalize all text files to LF
* text=auto eol=lf

# Windows-specific files must stay CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Maven wrapper must be LF
/mvnw text eol=lf

# Binary files — no line ending conversion
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.gif binary
